{
  "name": "@nighttrax/eslint-config",
  "private": true,
  "type": "module",
  "scripts": {
    "inspect": "config-inspector",
    "pub": "pnpm -r publish",
    "bump": "lerna version --conventional-commits",
    "bump:major": "lerna version major",
    "bump:minor": "lerna version minor",
    "bump:prerelease": "lerna version premajor",
    "lint": "TIMING=1 eslint ."
  },
  "devDependencies": {
    "@eslint/config-inspector": "~3.0.0",
    "eslint": "~10.6.0",
    "lerna": "~9.0.0",
    "prettier": "~3.9.0",
    "typescript": "~6.0.0"
  },
  "packageManager": "pnpm@11.10.0"
}
